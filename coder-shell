#!/bin/bash
# Coding Agent - Interactive Shell with Agent Running
# Starts Erlang shell with the coding agent loaded
# Usage: ./coder-shell

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="$SCRIPT_DIR/_build/default/lib"

# Check if build exists
if [ ! -d "$BUILD_DIR" ]; then
    echo "Build not found. Running rebar3 compile..."
    cd "$SCRIPT_DIR"
    rebar3 compile
    if [ $? -ne 0 ]; then
        echo "Compilation failed!"
        exit 1
    fi
fi

# Start interactive Erlang shell with coding_agent loaded
cd "$SCRIPT_DIR"
exec erl -pa "$BUILD_DIR"/*/ebin \
    -eval "application:ensure_all_started(coding_agent), io:format('~nCoding Agent started.~n'), io:format('Modules loaded:~n  coding_agent_memory (memory management)~n  coding_agent_healer (crash recovery)~n  coding_agent_self (self-modification)~n  coding_agent_session (conversational agent)~n'), io:format('~nUseful commands:~n  coding_agent_repl:start().  - Start interactive REPL~n  coding_agent_memory:status().  - Check memory~n  coding_agent_self:create_checkpoint().~n~n')" \
    -name coder@127.0.0.1 \
    -setcookie coder_cookie